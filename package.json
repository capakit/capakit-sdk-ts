{
    "name": "capakit-sdk",
    "version": "0.0.1",
    "description": "TypeScript SDK for CapaKit Workloads.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/capakit/capakit-sdk-ts.git"
    },
    "bugs": {
        "url": "https://github.com/capakit/capakit-sdk-ts/issues"
    },
    "homepage": "https://github.com/capakit/capakit-sdk-ts#readme",
    "type": "module",
    "files": [
        "src"
    ],
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./public-types": {
            "types": "./src/public-types.ts",
            "default": "./src/public-types.ts"
        }
    },
    "scripts": {
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "check": "npm run typecheck && npm test",
        "pack:dry-run": "npm pack --dry-run"
    },
    "dependencies": {
        "@a2a-js/sdk": "^0.3.4",
        "@anthropic-ai/sdk": "^0.93.0",
        "@google/genai": "^1.51.0",
        "@modelcontextprotocol/sdk": "1.29.0",
        "openai": "^6.3.0"
    },
    "devDependencies": {
        "@types/node": "22.12.0",
        "typescript": "5.5.4",
        "vitest": "^3.2.4"
    }
}
